# lofice — 환경 변수 예시 (복사: .env.local)
# Supabase 프로젝트: lawbox (ref: mvtkfefmqmsvkhltzyqi)

# Supabase (Phase 1 이중 저장 — 없으면 로컬만 동작)
NEXT_PUBLIC_SUPABASE_URL=https://mvtkfefmqmsvkhltzyqi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# hwpx-skill API (HWP 정규화, DVC, 양식, 암호 해제)
NEXT_PUBLIC_HWPX_SKILL_URL=https://lofice-hwpx-skill-api.vercel.app

# lofice Pro API (LibreOffice headless — office-convert-api)
# 로컬: docker compose up -d (loficepro) 또는 scripts/start-local-dev.ps1
NEXT_PUBLIC_OFFICE_CONVERT_URL=http://localhost:8200
# 프로덕션 폴백: https://lofice-office-convert.vercel.app

# excel-convert API (Phase 3 XLSX 분석)
NEXT_PUBLIC_EXCEL_CONVERT_URL=https://lofice-excel-convert.vercel.app

# python-office API (Phase 2 배치: PPT→PDF, Excel 분할)
NEXT_PUBLIC_PYTHON_OFFICE_URL=https://lofice-python-office.vercel.app

# msoffice C++ API (선택 — Electron/Windows)
NEXT_PUBLIC_MSOFFICE_CRYPTO_URL=

# rhwp studio (한글 편집 iframe)
NEXT_PUBLIC_RHWP_STUDIO_URL=https://studio.rhwp.dev
