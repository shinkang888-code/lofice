# lofice — 환경 변수 예시 (복사: .env.local)

# Supabase (Phase 1 이중 저장 — 없으면 로컬만 동작)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# hwpx-skill API (HWP 정규화, DVC, 양식, 암호 해제)
NEXT_PUBLIC_HWPX_SKILL_URL=https://lofice-hwpx-skill-api.vercel.app

# office-convert API (레거시 Office 정규화, HWPX→DOCX, LibreOffice)
NEXT_PUBLIC_OFFICE_CONVERT_URL=https://lofice-office-convert.vercel.app

# excel-convert API (XLSX 분석·CSV 변환)
NEXT_PUBLIC_EXCEL_CONVERT_URL=https://lofice-excel-convert.vercel.app

# python-office API (PPT→PDF 등 배치)
NEXT_PUBLIC_PYTHON_OFFICE_URL=https://lofice-python-office.vercel.app

# msoffice API (선택 — 네이티브 msoffice-crypt.exe)
NEXT_PUBLIC_MSOFFICE_CRYPTO_URL=https://lofice-msoffice-api.vercel.app

# rhwp studio (한글 편집 iframe)
NEXT_PUBLIC_RHWP_STUDIO_URL=https://studio.rhwp.dev
