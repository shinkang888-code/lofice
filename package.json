{
  "name": "lofice",
  "version": "2.19.0",
  "description": "lofice(로피스) - 웹 기반 통합 문서 뷰어 & 편집기",
  "author": "lofice",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-i18n-packs.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "android:build": "npm run build && npx cap sync android",
    "android:apk": "scripts\\build-android.bat",
    "test:parsers": "node scripts/create-test-fixtures.mjs && node scripts/test-parsers.mjs",
    "package:releases": "powershell -ExecutionPolicy Bypass -File scripts/package-releases.ps1",
    "assets:generate": "npx capacitor-assets generate --android",
    "build:electron": "next build",
    "prebuild:win": "node scripts/generate-icon.js",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:win": "npm run build:electron && electron-builder --win",
    "build:win:portable": "npm run build:electron && electron-builder --win portable",
    "postinstall": "node scripts/copy-native-assets.js"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.2",
    "@capacitor/share": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@docmentis/udoc-viewer": "^0.7.2",
    "@eigenpal/docx-editor-react": "^1.6.1",
    "@microscope-js/core": "^0.1.5",
    "@microscope-js/react": "^0.1.5",
    "@microscope-js/renderer-docx": "^0.1.5",
    "@microscope-js/renderer-image": "^0.1.5",
    "@microscope-js/renderer-pdf": "^0.1.5",
    "@microscope-js/renderer-pptx": "^0.1.5",
    "@microscope-js/renderer-xlsx": "^0.1.5",
    "@rhwp/core": "^0.7.15",
    "@rhwp/editor": "^0.7.15",
    "@ssabrojs/hwpxjs": "^0.4.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "7z-wasm": "^1.2.0",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^4.5.1",
    "hwp.js": "^0.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.9.0",
    "next": "^15.1.3",
    "officecrypto-tool": "^0.0.19",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "pptxgenjs": "^4.0.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.9",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0",
    "@types/node": "^22.10.5",
    "@types/plist": "^3.0.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.lofice.app",
    "productName": "lofice",
    "copyright": "Copyright © 2026 lofice",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "lofice-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "lofice",
      "installerLanguages": [
        "ko_KR",
        "en_US"
      ],
      "language": "2066"
    },
    "fileAssociations": [
      {
        "ext": "hwpx",
        "name": "HWPX Document",
        "description": "한글 개방형 문서",
        "role": "Editor",
        "icon": "public/lofice-icon.png"
      },
      {
        "ext": "hwp",
        "name": "HWP Document",
        "description": "한글 문서",
        "role": "Editor"
      },
      {
        "ext": "docx",
        "name": "Word Document",
        "description": "Microsoft Word 문서",
        "role": "Editor"
      },
      {
        "ext": "doc",
        "name": "Word Document (Legacy)",
        "description": "Microsoft Word 문서",
        "role": "Editor"
      },
      {
        "ext": "xlsx",
        "name": "Excel Spreadsheet",
        "description": "Microsoft Excel 스프레드시트",
        "role": "Editor"
      },
      {
        "ext": "xls",
        "name": "Excel Spreadsheet (Legacy)",
        "description": "Microsoft Excel 스프레드시트",
        "role": "Editor"
      },
      {
        "ext": "csv",
        "name": "CSV File",
        "description": "쉼표로 구분된 값",
        "role": "Editor"
      },
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF 문서",
        "role": "Viewer"
      },
      {
        "ext": "txt",
        "name": "Text Document",
        "description": "텍스트 문서",
        "role": "Editor"
      }
    ]
  }
}
