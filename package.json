{
  "name": "oneoffice",
  "version": "0.1.0",
  "description": "OneOffice - 광고 없는 무료 문서 뷰어 & 오피스",
  "author": "OneOffice",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "android:build": "npm run build && npx cap sync android",
    "android:apk": "scripts\\build-android.bat",
    "package:releases": "powershell -ExecutionPolicy Bypass -File scripts/package-releases.ps1",
    "assets:generate": "npx capacitor-assets generate --android",
    "build:electron": "next build",
    "prebuild:win": "node scripts/generate-icon.js",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:win": "npm run build:electron && electron-builder --win",
    "build:win:portable": "npm run build:electron && electron-builder --win portable"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.2",
    "@capacitor/share": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^4.5.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.9.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.oneoffice.app",
    "productName": "OneOffice",
    "copyright": "Copyright © 2026 OneOffice",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "OneOffice-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OneOffice",
      "installerLanguages": [
        "ko_KR",
        "en_US"
      ],
      "language": "2066"
    },
    "fileAssociations": [
      {
        "ext": "hwpx",
        "name": "HWPX Document",
        "description": "한글 개방형 문서",
        "role": "Editor",
        "icon": "public/oneoffice-app-icon.png"
      },
      {
        "ext": "hwp",
        "name": "HWP Document",
        "description": "한글 문서",
        "role": "Editor"
      },
      {
        "ext": "docx",
        "name": "Word Document",
        "description": "Microsoft Word 문서",
        "role": "Editor"
      },
      {
        "ext": "doc",
        "name": "Word Document (Legacy)",
        "description": "Microsoft Word 문서",
        "role": "Editor"
      },
      {
        "ext": "xlsx",
        "name": "Excel Spreadsheet",
        "description": "Microsoft Excel 스프레드시트",
        "role": "Editor"
      },
      {
        "ext": "xls",
        "name": "Excel Spreadsheet (Legacy)",
        "description": "Microsoft Excel 스프레드시트",
        "role": "Editor"
      },
      {
        "ext": "csv",
        "name": "CSV File",
        "description": "쉼표로 구분된 값",
        "role": "Editor"
      },
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF 문서",
        "role": "Viewer"
      },
      {
        "ext": "txt",
        "name": "Text Document",
        "description": "텍스트 문서",
        "role": "Editor"
      }
    ]
  }
}
